# Webhook URLs (not committed – use .env locally)
# Used for: dev proxy (avoids CORS) and default config when none saved

VITE_ASK_WEBHOOK_URL=https://your-n8n-host.com/webhook/ask
VITE_INGEST_WEBHOOK_URL=https://your-n8n-host.com/webhook/ingest

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth (simple owner-only gate)
VITE_AUTH_USERNAME=your-username
VITE_AUTH_PASSWORD=your-password
